FROM alpine:3.24 AS builder

WORKDIR /src
COPY . .

RUN apk add --no-cache bash git patch
RUN patch -p1 < patches/fallback-health-fields.patch
RUN bash scripts/build.alpine.release.sh

FROM alpine:3.24

RUN apk add --no-cache ca-certificates tzdata

WORKDIR /base
COPY --from=builder /src/subconverter/ /base/

EXPOSE 25500
CMD ["./subconverter"]
